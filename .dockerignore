# Docker build context exclusions
# Keeps the image lean by not sending dev/test artifacts to the Docker daemon.

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# Environment file (injected at runtime via docker-compose env_file or -e flags)
.env

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
tests/

# IDE / OS artefacts
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Dev tooling
Makefile
README.md

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
